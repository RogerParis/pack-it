{
  "name": "pack-it",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "postinstall": "patch-package",
    "test": "jest",
    "test:coverage": "jest --coverage --passWithNoTests",
    "lint": "eslint --ext .js,.jsx,.ts,.tsx --ignore-pattern 'node_modules/*' --ignore-pattern 'android/*' --ignore-pattern 'ios/*' --ignore-pattern '.expo/*' app/ components/ services/ store/ theme/ types/ utils/",
    "lint:fix": "eslint --ext .js,.jsx,.ts,.tsx --ignore-pattern 'node_modules/*' --ignore-pattern 'android/*' --ignore-pattern 'ios/*' --ignore-pattern '.expo/*' app/ components/ services/ store/ theme/ types/ utils/ --fix"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.2",
    "@react-native-community/datetimepicker": "8.6.0",
    "@react-native-firebase/app": "^23.8.8",
    "@react-native-firebase/auth": "^23.8.8",
    "@react-native-firebase/firestore": "^23.8.8",
    "@react-native-firebase/vertexai": "^23.8.8",
    "axios": "^1.9.0",
    "dotenv": "^16.5.0",
    "expo": "^55.0.0",
    "expo-linear-gradient": "~55.0.13",
    "expo-linking": "~55.0.14",
    "expo-router": "~55.0.13",
    "expo-status-bar": "~55.0.5",
    "expo-system-ui": "^55.0.16",
    "immer": "^10.1.1",
    "react": "19.2.0",
    "react-native": "0.83.6",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-get-random-values": "^1.11.0",
    "react-native-svg": "~15.15.4",
    "react-native-mmkv": "^4.3.1",
    "react-native-nitro-modules": "^0.35.5",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-worklets": "~0.7.0",
    "uuid": "^11.1.0",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-hooks": "^8.0.1",
    "@testing-library/react-native": "^13.2.0",
    "@types/jest": "^29.5.12",
    "@types/lodash": "^4.17.16",
    "@types/react": "^19.0.0",
    "@types/react-native": "^0.73.0",
    "@types/react-test-renderer": "^19.0.0",
    "@typescript-eslint/eslint-plugin": "^8.26.0",
    "@typescript-eslint/parser": "^8.26.0",
    "axios-mock-adapter": "^2.1.0",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.2.3",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "eslint-plugin-unused-imports": "^4.1.4",
    "expo-dev-client": "~55.0.28",
    "jest": "^29.7.0",
    "jest-expo": "~55.0.16",
    "msw": "^2.7.3",
    "patch-package": "^8.0.0",
    "prettier": "^3.5.3",
    "react-test-renderer": "19.0.0",
    "typescript": "~5.9.2"
  },
  "private": true,
  "jest": {
    "preset": "jest-expo",
    "transformIgnorePatterns": [
      "node_modules/(?!((jest-)?react-native|@react-native(-community)?)|expo(nent)?|@expo(nent)?/.*|react-navigation|@react-navigation/.*)"
    ],
    "moduleNameMapper": {
      "^uuid$": "<rootDir>/node_modules/uuid/dist/cjs/index.js",
      "^@/(.*)$": "<rootDir>/$1"
    },
    "setupFiles": [
      "<rootDir>/jest.setup.ts"
    ]
  }
}
